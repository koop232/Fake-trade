--[[
    ULTRA FAST ESCAPE SPAMMER
    - Maximum speed (RenderStepped = 60+ times per second)
    - No delay between key presses
    - Press E to toggle on/off
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild("PlayerGui")

-- Remove old copy
local oldGui = playerGui:FindFirstChild("EscapeSpammer")
if oldGui then
	oldGui:Destroy()
end

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "EscapeSpammer"
gui.ResetOnSpawn = false
gui.IgnoreGuiInset = true
gui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 150, 0, 50)
frame.Position = UDim2.new(0.5, -75, 0.9, -25)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.BackgroundTransparency = 0.2
frame.BorderSizePixel = 0
frame.Active = true
frame.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 1, 0)
title.BackgroundTransparency = 1
title.Text = "⚡ FAST ESCAPE"
title.TextColor3 = Color3.fromRGB(0, 255, 0)
title.Font = Enum.Font.SourceSansBold
title.TextSize = 20
title.Parent = frame

-- Dragging
do
	local dragging = false
	local dragStart
	local startPos

	local function update(input)
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end

	title.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			update(input)
		end
	end)
end

-- Spam state
local spamming = true

-- ULTRA FAST - every frame (60+ times/sec)
RunService.RenderStepped:Connect(function()
	if spamming then
		pcall(function()
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Escape, false, nil)
			VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Escape, false, nil)
		end)
	end
end)

-- Toggle with E key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.E then
		spamming = not spamming
		title.Text = spamming and "⚡ FAST ESCAPE" or "⏸️ ESC PAUSED"
		title.TextColor3 = spamming and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 0)
	end
end)

print("✅ ULTRA FAST ESCAPE SPAMMER LOADED")
print("🔹 Press E to toggle")
print("🔹 Speed: 60+ times/second")
